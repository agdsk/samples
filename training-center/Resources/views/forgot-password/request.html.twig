{% set page_title = 'Reset Password' %}
{% extends 'layout/standard.html.twig' %}

{% block body %}
    <section class="boxy-form">
        <h1>Reset your password</h1>

        <p><strong>Florida Hospital Employees</strong><br>To login to your account, use your OpID and password. You can not reset your password here. If you are having trouble logging in, contact your supervisor.</p>

        <p><strong>Non-Employees</strong><br>Enter your email address to receive an email with a link to reset your password.</p>

        {{ form(form) }}
    </section>
{% endblock %}
