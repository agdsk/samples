{% extends 'layout/email.html.twig' %}

{% block title %}FHTC Update: Response to Your Registration Request{% endblock %}

{% block body %}
  <h1 style="font-family: 'Helvetica Neue', Helvetica, Arial, 'Lucida Grande', sans-serif; font-size: 36px; line-height: 1.2em; color: #111111; font-weight: 200; margin: 40px 0 14px; padding: 0;">FHTC Update: Response to Your Registration Request</h1>
        <p style="font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif; font-size: 14px; line-height: 1.6em; font-weight: normal; margin: 0 0 40px; padding: 0;">Your enrollment request for {{ Enrollment.Session.Course.name }} has not been accepted. You do not meet the criteria to enroll at this time. Log in to your FHTC account to explore other courses open for registration.</p>
        
    {% include 'email/includes/button.html.twig' 
      with {'text' : 'Get Started', 
          'link' : absolute_url(path('login'))} %}
        
{% endblock %}
