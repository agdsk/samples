{% extends 'layout/email.html.twig' %}

{% block title %}An Administrator Cancelled your Enrollment in {{ Session.Course.name }}{% endblock %}

{% block body %}
  <h1 style="font-family: 'Helvetica Neue', Helvetica, Arial, 'Lucida Grande', sans-serif; font-size: 36px; line-height: 1.2em; color: #111111; font-weight: 200; margin: 40px 0 14px; padding: 0;">An Administrator Cancelled your Enrollment in {{ Session.Course.name }}</h1>
        <p style="font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif; font-size: 14px; line-height: 1.6em; font-weight: normal; margin: 0 0 40px; padding: 0;">Your enrollment in {{ Session.Course.name }} on {{ Session.date1|date('F d, Y') }} at {{ Session.start_time1|date('g:i A') }} has been cancelled by an administrator. Log in to your FHTC account to enroll in another course. </p>
        
    {% include 'email/includes/button.html.twig' 
      with {'text' : 'Get Started', 
          'link' : absolute_url(path('login'))} %}
        
{% endblock %}
